# =========================================================
# FINDASH — نمونه متغیرهای محیطی
# کپی کنید به .env.local (dev) یا .env.production (prod)
# هرگز این فایل را با مقادیر واقعی پر نکنید
# =========================================================

# ── Application ──────────────────────────────────────────
ENVIRONMENT=production          # development | production
DEBUG=false
LOG_LEVEL=INFO

# ── Security (REQUIRED — حداقل ۶۴ کاراکتر تصادفی) ───────
# تولید: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_SECRET_KEY=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_STRING
NEXTAUTH_SECRET=REPLACE_WITH_YET_ANOTHER_64_CHAR_RANDOM_STRING
BCRYPT_ROUNDS=12
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:STRONG_PASSWORD@db:5432/trading_db
DB_HOST=db
DB_PORT=5432
DB_NAME=trading_db
DB_USER=postgres
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
REDIS_DB=0

# ── Celery ───────────────────────────────────────────────
CELERY_BROKER_URL=redis://:REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:REDIS_PASSWORD@redis:6379/0
CELERY_TIMEZONE=Asia/Tehran

# ── NextAuth ─────────────────────────────────────────────
NEXTAUTH_URL=https://yourdomain.ir
NEXT_PUBLIC_API_URL=https://yourdomain.ir/api

# ── Backend Internal URL (داخل Docker) ───────────────────
BACKEND_INTERNAL_URL=http://api:8000
APP_BASE_URL=https://yourdomain.ir

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=https://yourdomain.ir
CORS_ALLOW_CREDENTIALS=true

# ── Payment Gateway ───────────────────────────────────────
# برای sandbox از: 1344b5d4-0048-11e8-94db-005056a205be استفاده کنید
# برای production: ID واقعی از panel.zarinpal.com
ZARINPAL_MERCHANT_ID=REPLACE_WITH_REAL_ZARINPAL_MERCHANT_ID

# ── SMS (TASK-012 — OTP Auth) ────────────────────────────
# ارائه‌دهنده پیشنهادی: KaveNegar (kavenegar.com)
SMS_PROVIDER=kavenegar
SMS_API_KEY=REPLACE_WITH_KAVENEGAR_API_KEY
SMS_SENDER_LINE=10008663

# ── Monitoring ───────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_GRAFANA_PASSWORD
TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_TELEGRAM_CHAT_ID

# ── External APIs (اختیاری — برای هوش مصنوعی) ───────────
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
NEWS_API_KEY=
HF_TOKEN=

# ── Email (اختیاری) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true

# ── File Storage ─────────────────────────────────────────
DATA_DIR=/app/data
LOGS_DIR=/app/logs
MODELS_DIR=/app/models
UPLOAD_DIR=/app/uploads

# ── Docker Port Overrides (اختیاری) ──────────────────────
DB_HOST_PORT=5434
REDIS_HOST_PORT=6380

# ── Trading Defaults ─────────────────────────────────────
DEFAULT_PORTFOLIO_VALUE=100000000   # ۱۰۰ میلیون تومان
MAX_POSITION_SIZE=0.1
RISK_FREE_RATE=0.25                 # نرخ بدون ریسک ایران (~۲۵٪)
DEFAULT_VOLATILITY=0.3
